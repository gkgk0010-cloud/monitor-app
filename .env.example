# 예시 파일 (실제 값 없이 저장소에 포함 가능).

# 필수 — Supabase Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 필수(서버 전용) — 선생님 회원가입 teachers/academies INSERT (Vercel·.env.local)
# Project Settings → API → service_role (절대 NEXT_PUBLIC_ 붙이지 말 것)
SUPABASE_SERVICE_ROLE_KEY=

# 선택 — 학생 브라우저에서 Google TTS 직호출 시
NEXT_PUBLIC_GOOGLE_TTS_API_KEY=

# 서버(API 라우트) — 코드: app/api/claude, autofill, suggest-example, boost-feedback
ANTHROPIC_API_KEY=

# 서버 — app/api/unsplash
UNSPLASH_ACCESS_KEY=

# 선택 — 로컬 기본 학원·선생 (utils/defaults.js). 비워 두어도 됨.
# NEXT_PUBLIC_DEFAULT_ACADEMY_ID=
# NEXT_PUBLIC_DEFAULT_TEACHER_ID=

# 선택 — teacher/live-battle: 콤마 구분 로그인 이메일. 해당 계정만 전 학원 PvP 라이브 중계(DB RLS 허용 시).
# NEXT_PUBLIC_LIVE_BATTLE_SUPER_TEACHER_EMAILS=you@school.kr,admin@example.com
